{
  "browserslist": [
    "extends browserslist-config-baseline",
    "current node"
  ],
  "dependencies": {
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.0.3",
    "@tailwindcss/cli": "^4.2.2",
    "calendar-link": "^2.11.0",
    "hono": "^4.12.8",
    "lodash": "^4.17.23",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@ethang/eslint-config": "^25.5.2",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@portabletext/types": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "browserslist-config-baseline": "^0.5.0",
    "eslint": "^10.1.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=24"
  },
  "name": "sterett-hono",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "pnpm tw && bun scripts/stamp-sw.ts && wrangler deploy --minify",
    "dev": "wrangler dev",
    "lint": "eslint . --fix --concurrency=auto",
    "test": "pnpm test:vitest && pnpm test:playwright",
    "test:playwright": "playwright test",
    "test:vitest": "vitest run --coverage",
    "tw": "pnpx @tailwindcss/cli -i ./src/index.css -o ./public/index.css",
    "tw:watch": "pnpx @tailwindcss/cli -i ./src/index.css -o ./public/index.css --watch"
  },
  "type": "module"
}
