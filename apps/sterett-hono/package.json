{
  "browserslist": [
    "extends browserslist-config-baseline",
    "current node"
  ],
  "dependencies": {
    "@ethang/service-worker": "workspace:*",
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/cli": "^4.2.4",
    "calendar-link": "^2.11.0",
    "hono": "^4.12.14",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "@axe-core/playwright": "^4.11.2",
    "@ethang/eslint-config": "^25.15.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@portabletext/types": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "browserslist-config-baseline": "^0.5.0",
    "eslint": "^10.2.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "engines": {
    "node": ">=24"
  },
  "name": "sterett-hono",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "bun build.ts && pnpm tw && wrangler deploy --minify",
    "dev": "wrangler dev",
    "lint": "eslint . --fix --cache && pnpm tsc --noEmit",
    "test": "pnpm test:vitest",
    "test:playwright": "playwright test",
    "test:vitest": "vitest run --coverage",
    "tw": "pnpx @tailwindcss/cli -i ./src/index.css -o ./public/index.css",
    "tw:watch": "pnpx @tailwindcss/cli -i ./src/index.css -o ./public/index.css --watch"
  },
  "type": "module",
  "version": "1.0.0"
}
