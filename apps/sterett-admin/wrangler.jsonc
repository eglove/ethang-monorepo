{
  "$schema": "node_modules/wrangler/config-schema.json",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "compatibility_date": "2026-06-11",
  "main": "src/index.ts",
  "name": "sterett-admin",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "custom_domain": true,
      "pattern": "admin.sterettcreekvillagetrustee.com"
    }
  ]
}
