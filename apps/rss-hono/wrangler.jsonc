{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "TBD",
      "database_name": "rss-hono-db",
      "remote": true
    }
  ],
  "main": "src/index.ts",
  "name": "rss-hono",
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
