{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.ts",
  "name": "ethang-graphql",
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "services": [
    {
      "binding": "ethang_rss",
      "service": "ethang-rss"
    }
  ]
}
