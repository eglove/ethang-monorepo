{
  "browserslist": [
    "extends browserslist-config-baseline",
    "current node"
  ],
  "dependencies": {
    "@ethang/markdown-generator": "^1.2.0",
    "@ethang/store": "^2.3.2",
    "@ethang/toolbelt": "^4.4.11",
    "@portabletext/toolkit": "^5.0.2",
    "@sanity/block-content-to-html": "^2.0.0",
    "@sanity/client": "^7.20.0",
    "bignumber.js": "^10.0.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.9",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@ethang/eslint-config": "^25.11.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "browserslist-config-baseline": "^0.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "fast-glob": "^3.3.3",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=24"
  },
  "name": "ethang-hono",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "bun ./build.ts && bun scripts/stamp-sw.ts && wrangler deploy --minify",
    "dev": "run-p tailwind wrangler:dev",
    "drizzle:generate": "drizzle-kit generate",
    "lint": "eslint . --fix --cache && pnpm tsc --noEmit",
    "tailwind": "tailwindcss -i ./src/index.css -o ./public/index.css --watch",
    "test": "pnpm test:vitest",
    "test:e2e": "playwright test",
    "test:vitest": "vitest run --coverage",
    "wrangler:dev": "wrangler dev"
  },
  "type": "module"
}
