{
  "browserslist": [
    "extends browserslist-config-baseline",
    "current node"
  ],
  "dependencies": {
    "@ethang/hono-middleware": "workspace:*",
    "@ethang/markdown-generator": "^1.2.0",
    "@ethang/store": "^3.0.0",
    "@ethang/toolbelt": "^4.5.0",
    "@portabletext/toolkit": "^5.0.2",
    "@sanity/block-content-to-html": "^2.0.0",
    "@sanity/client": "^7.22.0",
    "bignumber.js": "^11.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.16",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@ethang/eslint-config": "^25.17.2",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "browserslist-config-baseline": "^0.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "fast-glob": "^3.3.3",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "engines": {
    "node": ">=24"
  },
  "name": "ethang-hono",
  "scripts": {
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "bun ./build.ts && wrangler deploy --minify",
    "dev": "run-p tailwind wrangler:dev",
    "drizzle:generate": "drizzle-kit generate",
    "lint": "eslint . --fix --cache && pnpm tsc --noEmit",
    "tailwind": "tailwindcss -i ./src/index.css -o ./public/index.css --watch",
    "test": "pnpm test:vitest",
    "test:e2e": "playwright test",
    "test:vitest": "vitest run --coverage",
    "wrangler:dev": "wrangler dev"
  },
  "type": "module",
  "version": "1.0.0"
}
