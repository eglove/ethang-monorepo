{
  "permissions": {
    "allow": [
      "Bash",
      "PowerShell",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Skill",
      "WebFetch",
      "mcp__sonarqube__search_sonar_issues_in_projects",
      "mcp__sonarqube__search_my_sonarqube_projects",
      "mcp__sonarqube__list_pull_requests",
      "mcp__sonarqube__get_project_quality_gate_status",
      "mcp__sonarqube__search_duplicated_files",
      "mcp__sonarqube__get_duplications",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_github_github__get_file_contents",
      "mcp__plugin_github_github__pull_request_read",
      "mcp__plugin_github_github__get_tag",
      "mcp__plugin_github_github__list_tags",
      "mcp__plugin_github_github__get_latest_release",
      "mcp__plugin_github_github__get_commit",
      "mcp__webstorm__read_file",
      "mcp__webstorm__find_files_by_glob",
      "mcp__webstorm__get_file_text_by_path",
      "mcp__webstorm__replace_text_in_file",
      "mcp__webstorm__search_in_files_by_text",
      "mcp__webstorm__find_files_by_name_keyword",
      "mcp__webstorm__execute_terminal_command",
      "mcp__webstorm__create_new_file",
      "mcp__webstorm__list_directory_tree",
      "mcp__webstorm__search_file",
      "Bash(\"c:\\users\\glove\\projects\\tla-toolbox\\plugins\\org.lamport.openjdk.win32.x86_64_14.0.1.7\\jre\\bin\\java.exe\" *)",
      "Bash(type *)",
      "Bash(powershell.exe *)",
      "mcp__webstorm__build_project",
      "WebSearch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".qwen/hooks/quality-check.sh",
            "name": "quality-check",
            "description": "Run lint, type-check, and tests after file edits",
            "timeout": 120000
          }
        ]
      }
    ]
  },
  "$version": 3
}