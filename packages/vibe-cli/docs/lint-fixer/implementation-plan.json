{
  "topic": "Lint-Fixer Agent",
  "revision": 4,
  "revisionDate": "2026-04-07",
  "architecturalDecisions": [
    {
      "id": "AD1",
      "title": "Clone-Before-Mutate State Discipline",
      "summary": "Every phase function receives a state hashtable and returns a new hashtable. The original is never mutated. Copy-LintFixerState performs shallow clone. Runner replaces state only after successful return."
    },
    {
      "id": "AD2",
      "title": "Suppression Extracted to Shared Utility",
      "summary": "Invoke-LintFixerSuppress in suppress.ps1 handles eslint-disable-next-line insertion with atomic rollback and double-fault handling (H9). Consolidates same-line different-rule violations into single directives (D-1). Used by both VerifyCapReached and ManualSuppressExhausted."
    },
    {
      "id": "AD3",
      "title": "Per-Violation Attempt Tracking with Min-Aggregation",
      "summary": "Implementation tracks attempts per file:line:rule in _attemptTracker hashtable. TLA+ attemptsLeft = min(tracker.Values). New violations get MaxAttempts budget. Resolved violations are removed. Identity is a 3-tuple — same file:line with different rules produces different keys (D-1). Line-drift heuristic scoped to same-file + same-rule only (D-1). Guard interaction (P-1): when attemptsLeft=0, ManualFixNone is disabled — ManualSuppressExhausted fires instead.",
      "addressesObjections": ["H2", "D-1", "P-1"]
    },
    {
      "id": "AD4",
      "title": "Commit Trailers for Structural Identity",
      "summary": "Lint-fixer commits include Lint-Fixer-Run-Id: <uuid> as a git commit trailer. Machine-parseable via %(trailers:key=...). Survives message rewording. UUID is unique per run, generated in New-LintFixerState as _runId. Used by stage 9 crash recovery. Foreign trailer triggers re-dispatch with fresh state (P-8), not skip.",
      "addressesObjections": ["D-4", "P-8"]
    }
  ],
